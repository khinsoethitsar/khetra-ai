rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - id: string (required) - Unique session ID
    //   - userId: string (required) - Owner's UID
    //   - title: string (required) - Session title
    //   - messages: list (required) - Array of message objects
    //   - updatedAt: string (required) - ISO 8601 timestamp
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required) - User's UID
    //   - displayName: string (required) - User's display name
    //   - photoURL: string (optional) - User's avatar URL
    //   - email: string (required) - User's email
    //   - updatedAt: string (required) - ISO 8601 timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['id', 'userId', 'title', 'messages', 'updatedAt']) &&
             data.id is string &&
             data.userId is string &&
             data.title is string && data.title.size() <= 500 &&
             data.messages is list && data.messages.size() <= 1000 &&
             data.updatedAt is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'email', 'updatedAt']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.email is string &&
             data.updatedAt is string;
    }

    match /sessions/{sessionId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && 
                      isValidSession(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId) && 
                      isValidSession(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated(); // Allow authenticated users to read profiles (e.g. for chat)
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
